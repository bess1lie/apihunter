# apihunter — Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env && $EDITOR .env

# Authorization header value for authenticated requests (optional).
# Format: "Bearer <token>" or any custom scheme.
# APIHUNTER_AUTH_HEADER=Bearer eyJhbGciOi...

# Default requests per second (optional, default: 10).
# APIHUNTER_RATE=10

# Default request timeout in seconds (optional, default: 10).
# APIHUNTER_TIMEOUT=10
